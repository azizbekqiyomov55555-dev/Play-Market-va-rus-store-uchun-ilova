.part-btn { background: rgb(17, 17, 17); border: 1.5px solid rgb(51, 51, 51); color: white; padding: 14px; border-radius: 12px; font-weight: 900; text-align: center; font-size: 13px; }

.part-btn.selected { background: var(--accent); color: rgb(0, 0, 0); border-color: var(--accent); }

.detail-play-bar { position: sticky; bottom: 0px; left: 0px; width: 100%; background: linear-gradient(0deg, rgb(0, 0, 0) 70%, transparent 100%); padding: 10px 16px 24px; box-sizing: border-box; z-index: 10; }

.btn-play-green { background: linear-gradient(90deg, rgb(0, 255, 115), rgb(0, 204, 92)); color: rgb(0, 0, 0); width: 100%; padding: 18px; border-radius: 15px; font-size: 19px; font-weight: 900; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; display: flex; align-items: center; justify-content: center; gap: 15px; }

#player { position: fixed; top: 0px; left: 0px; width: 100%; height: 100%; background: rgb(0, 0, 0); z-index: 3000; display: none; overflow: visible; }

.modal { display: none; position: fixed; top: 0px; left: 0px; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.95); z-index: 2500; overflow-y: auto; }

.modal-content { background: rgb(17, 17, 17); border-radius: 30px; padding: 25px; margin: 50px 15px; border: 1px solid var(--border); }

input, select { width: 100%; padding: 15px; background: rgb(26, 26, 26); border: 1px solid rgb(51, 51, 51); color: white; border-radius: 12px; margin-bottom: 15px; box-sizing: border-box; font-size: 16px; }

.btn-adm { background: var(--accent); color: rgb(0, 0, 0); width: 100%; padding: 16px; border-radius: 12px; font-weight: 900; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; margin-bottom: 10px; }

.history-card { background: rgb(17, 17, 17); padding: 15px; border-radius: 15px; border-left: 4px solid var(--accent); margin-bottom: 12px; }

.stack-hero { position: relative; width: 100%; margin: 0px auto 32px; height: 370px; overflow: hidden; }

.stack-viewport { position: relative; width: 86%; margin: 0px auto; height: 320px; }

.stack-card { position: absolute; width: 100%; height: 100%; border-radius: 26px; overflow: hidden; cursor: pointer; will-change: transform, opacity; box-shadow: rgba(0, 0, 0, 0.7) 0px 8px 32px; }

.stack-card img { width: 100%; height: 100%; object-fit: cover; display: block; pointer-events: none; user-select: none; }

.stack-card-overlay { position: absolute; inset: 0px; background: linear-gradient(0deg, rgba(0, 0, 0, 0.88) 0%, rgba(0, 0, 0, 0.15) 55%, transparent 100%); }

.stack-card-info { position: absolute; bottom: 0px; left: 0px; right: 0px; padding: 18px 18px 16px; }

.stack-card-title { font-size: 20px; font-weight: 900; text-transform: uppercase; line-height: 1.2; text-shadow: rgba(0, 0, 0, 0.9) 0px 2px 10px; margin-bottom: 7px; }

.stack-card-badge { display: inline-block; background: var(--accent); color: rgb(0, 0, 0); font-size: 11px; font-weight: 900; padding: 3px 10px; border-radius: 8px; }

.stack-card-badge.free { background: transparent; color: var(--accent); border: 1.5px solid var(--accent); }

.stack-dots { position: absolute; bottom: 0px; left: 0px; right: 0px; display: flex; justify-content: center; gap: 6px; padding: 8px 0px; }

.stack-dot { width: 7px; height: 7px; border-radius: 50%; background: rgb(51, 51, 51); transition: 0.3s; cursor: pointer; }

.stack-dot.active { background: var(--accent); transform: scale(1.45); box-shadow: rgba(0, 255, 115, 0.8) 0px 0px 8px; }

.hero-swiper { display: none; }

.hero-img { width: 100%; height: 100%; object-fit: cover; }

.swiper-pagination-bullet { background: rgb(0, 255, 115) !important; opacity: 0.25 !important; width: 8px !important; height: 8px !important; }

.swiper-pagination-bullet-active { opacity: 1 !important; transform: scale(1.4) !important; }

.del-item { display: flex; justify-content: space-between; align-items: center; background: rgb(26, 26, 26); padding: 12px; border-radius: 12px; margin-bottom: 10px; border: 1px solid rgb(51, 51, 51); }

@keyframes spinLoader { 
  100% { transform: rotate(360deg); }
}

.plan-card { background: linear-gradient(135deg, rgb(13, 31, 21) 0%, rgb(10, 10, 10) 50%, rgb(17, 34, 24) 100%); border: 2px solid rgba(0, 255, 115, 0.25); border-radius: 24px; padding: 22px 20px; margin-bottom: 18px; position: relative; overflow: hidden; cursor: pointer; transform: translateY(20px); opacity: 0; animation: 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0s 1 normal forwards running cardEnter; box-shadow: rgba(0, 255, 115, 0.08) 0px 8px 32px, rgba(255, 255, 255, 0.04) 0px 1px 0px inset; transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s, border-color 0.3s; }

.plan-card:nth-child(1) { animation-delay: 0.05s; }

.plan-card:nth-child(2) { animation-delay: 0.18s; }

.plan-card:nth-child(3) { animation-delay: 0.31s; }

.plan-card:nth-child(4) { animation-delay: 0.44s; }

.plan-card:nth-child(5) { animation-delay: 0.57s; }

@keyframes cardEnter { 
  0% { transform: translateY(40px) scale(0.92); opacity: 0; filter: blur(8px); }
  60% { transform: translateY(-4px) scale(1.02); opacity: 1; filter: blur(0px); }
  100% { transform: translateY(0px) scale(1); opacity: 1; filter: blur(0px); }
}

.plan-card:hover { transform: translateY(-4px) scale(1.02); border-color: rgba(0, 255, 115, 0.6); box-shadow: rgba(0, 255, 115, 0.25) 0px 16px 48px; }

.plan-card::before { content: ""; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%; background: conic-gradient(transparent 0%, rgba(0, 255, 115, 0.18) 25%, transparent 50%, rgba(0, 255, 115, 0.12) 75%, transparent 100%); animation: 6s linear 0s infinite normal none running spin; pointer-events: none; }

@keyframes spin { 
  100% { transform: rotate(360deg); }
}

.plan-card:active { transform: scale(0.97); border-color: var(--accent); }

.plan-card > * { position: relative; z-index: 2; }

.plan-name { font-size: 20px; font-weight: 900; background: linear-gradient(90deg, rgb(255, 255, 255), rgb(0, 255, 115)) text; -webkit-text-fill-color: transparent; letter-spacing: 0.5px; }

.plan-price { font-size: 32px; font-weight: 900; color: var(--accent); text-shadow: rgba(0, 255, 115, 0.6) 0px 0px 24px, rgba(0, 255, 115, 0.3) 0px 0px 4px; margin-top: 6px; animation: 2.5s ease-in-out 0s infinite normal none running priceGlow; }

@keyframes priceGlow { 
  0%, 100% { text-shadow: rgba(0, 255, 115, 0.6) 0px 0px 24px; }
  50% { text-shadow: rgba(0, 255, 115, 0.95) 0px 0px 36px, rgba(0, 255, 115, 0.5) 0px 0px 12px; }
}

.plan-duration { font-size: 13px; color: rgb(142, 165, 154); margin-top: 4px; font-weight: 600; }

.plan-buy-btn { background: linear-gradient(90deg, rgb(0, 255, 115), rgb(0, 204, 92), rgb(0, 255, 115)) 0% 0% / 200% 100%; color: rgb(0, 0, 0); border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; padding: 14px 28px; border-radius: 14px; font-weight: 900; font-size: 15px; margin-top: 14px; cursor: pointer; width: 100%; animation: 2s ease-in-out 0s infinite normal none running pulse-btn, 3s linear 0s infinite normal none running shimmer; transition: transform 0.15s; letter-spacing: 1px; }

.plan-buy-btn:active { transform: scale(0.95); }

@keyframes pulse-btn { 
  0%, 100% { box-shadow: rgba(0, 255, 115, 0.5) 0px 0px 0px 0px, rgba(0, 255, 115, 0.3) 0px 4px 16px; }
  50% { box-shadow: rgba(0, 255, 115, 0) 0px 0px 0px 14px, rgba(0, 255, 115, 0.5) 0px 4px 20px; }
}

@keyframes shimmer { 
  100% { background-position: 200% 0px; }
}

.success-overlay { position: fixed; inset: 0px; background: radial-gradient(circle, rgba(0, 255, 115, 0.18), rgba(0, 0, 0, 0.92)); backdrop-filter: blur(12px); z-index: 99999; display: none; align-items: center; justify-content: center; animation: 0.3s ease-out 0s 1 normal none running fadeBg; }

.success-overlay.show { display: flex; }

@keyframes fadeBg { 
  0% { opacity: 0; }
  100% { opacity: 1; }
}

.success-box { background: linear-gradient(160deg, rgb(10, 26, 16), rgb(0, 0, 0)); border: 2px solid rgb(0, 255, 115); border-radius: 28px; padding: 36px 28px; max-width: 320px; width: 88%; text-align: center; position: relative; box-shadow: rgba(0, 255, 115, 0.45) 0px 0px 80px, rgba(0, 255, 115, 0.08) 0px 0px 30px inset; animation: 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0s 1 normal none running popIn; }

@keyframes popIn { 
  0% { transform: scale(0.3) rotate(-15deg); opacity: 0; }
  60% { transform: scale(1.08) rotate(3deg); opacity: 1; }
  100% { transform: scale(1) rotate(0deg); opacity: 1; }
}

.success-check { width: 90px; height: 90px; margin: 0px auto 18px; border-radius: 50%; background: linear-gradient(135deg, rgb(0, 255, 115), rgb(0, 204, 92)); display: flex; align-items: center; justify-content: center; font-size: 54px; box-shadow: rgba(0, 255, 115, 0.7) 0px 0px 40px, rgba(0, 0, 0, 0.3) 0px -4px 12px inset; animation: 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) 0.2s 1 normal both running checkBounce, 2s ease-out 0.4s infinite normal none running ringPulse; }

@keyframes checkBounce { 
  0% { transform: scale(0) rotate(-180deg); }
  60% { transform: scale(1.2) rotate(10deg); }
  100% { transform: scale(1) rotate(0deg); }
}

@keyframes ringPulse { 
  0% { box-shadow: rgba(0, 255, 115, 0.7) 0px 0px 40px, rgba(0, 255, 115, 0.6) 0px 0px 0px 0px; }
  100% { box-shadow: rgba(0, 255, 115, 0.7) 0px 0px 40px, rgba(0, 255, 115, 0) 0px 0px 0px 30px; }
}

.success-title { font-size: 24px; font-weight: 900; color: rgb(255, 255, 255); margin-bottom: 8px; animation: 0.5s ease-out 0.4s 1 normal both running slideUp; }

.success-msg { font-size: 15px; color: rgb(142, 165, 154); margin-bottom: 6px; animation: 0.5s ease-out 0.5s 1 normal both running slideUp; }

.success-plan { font-size: 22px; font-weight: 900; color: rgb(0, 255, 115); margin: 10px 0px 18px; text-shadow: rgba(0, 255, 115, 0.6) 0px 0px 20px; animation: 0.5s ease-out 0.6s 1 normal both running slideUp; }

@keyframes slideUp { 
  0% { opacity: 0; transform: translateY(15px); }
  100% { opacity: 1; transform: translateY(0px); }
}

.success-ok-btn { background: linear-gradient(90deg, rgb(0, 255, 115), rgb(0, 204, 92)); color: rgb(0, 0, 0); border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; padding: 14px 40px; border-radius: 14px; font-weight: 900; font-size: 16px; cursor: pointer; box-shadow: rgba(0, 255, 115, 0.4) 0px 6px 20px; animation: 0.5s ease-out 0.7s 1 normal both running slideUp; letter-spacing: 1px; }

.success-ok-btn:active { transform: scale(0.95); }

.confetti-piece { position: fixed; width: 10px; height: 14px; top: -20px; z-index: 100000; opacity: 0; pointer-events: none; animation: 2.8s ease-out 0s 1 normal forwards running confettiFall; }

@keyframes confettiFall { 
  0% { transform: translateY(0px) rotate(0deg); opacity: 1; }
  100% { transform: translateY(110vh) rotate(720deg); opacity: 0; }
}

.promo-row { display: flex; justify-content: space-between; align-items: center; background: rgb(17, 17, 17); padding: 10px 14px; border-radius: 10px; margin-bottom: 8px; border: 1px solid rgb(42, 42, 42); }

.promo-tag { background: var(--accent); color: rgb(0, 0, 0); padding: 2px 8px; border-radius: 6px; font-size: 12px; font-weight: 900; }

.siz-card { background: rgb(14, 14, 14); border: 1.5px solid rgb(34, 34, 34); border-radius: 22px; padding: 18px 16px; position: relative; overflow: hidden; transition: transform 0.15s, border-color 0.2s; }

.siz-card:active { transform: scale(0.95); }

.siz-prem { border-color: rgb(58, 26, 26); }

.siz-prem:hover, .siz-prem:active { border-color: rgb(255, 107, 107); }

.siz-bal { border-color: rgb(26, 42, 26); }

.siz-bal:active { border-color: var(--accent); }

.siz-card-shine { position: absolute; top: -60%; left: -60%; width: 220%; height: 220%; background: conic-gradient(from 180deg, transparent 70%, rgba(255, 255, 255, 0.03) 85%, transparent 100%); animation: 6s linear 0s infinite normal none running spin; pointer-events: none; }

.siz-row { background: rgb(14, 14, 14); border: 1.5px solid var(--row-border, #222); border-radius: 20px; padding: 14px 16px; display: flex; align-items: center; gap: 14px; transition: transform 0.12s, background 0.15s; position: relative; overflow: hidden; }

.siz-row::after { content: ""; position: absolute; inset: 0px; background: var(--row-color, transparent); opacity: 0; transition: opacity 0.2s; pointer-events: none; border-radius: 18px; }

.siz-row:active { transform: scale(0.97); }

.siz-row:active::after { opacity: 1; }

.siz-row-icon { width: 44px; height: 44px; border-radius: 13px; display: flex; align-items: center; justify-content: center; font-size: 20px; border: 1.5px solid transparent; flex-shrink: 0; transition: transform 0.2s; }

.siz-row:active .siz-row-icon { transform: scale(1.15) rotate(-5deg); }

.siz-row-text { flex: 1 1 0%; }

.siz-row-text span { display: block; font-weight: 900; font-size: 15px; }

.siz-row-text small { display: block; font-size: 11px; color: rgb(102, 102, 102); margin-top: 2px; }

.siz-row-arrow { font-size: 22px; color: rgb(85, 85, 85); font-weight: 300; transition: transform 0.2s, color 0.2s; }

.siz-row:active .siz-row-arrow { transform: translateX(4px); color: var(--accent); }

.prize-row { display: flex; gap: 8px; align-items: center; margin-bottom: 10px; }

.prize-row input { margin-bottom: 0px; flex: 1 1 0%; }

.prize-row .prize-label { font-size: 13px; font-weight: 900; color: rgb(255, 215, 0); white-space: nowrap; min-width: 40px; }

#toastBox { position: fixed; top: 24px; left: 50%; transform: translateX(-50%); z-index: 9999; display: flex; flex-direction: column; align-items: center; gap: 10px; pointer-events: none; width: 90%; max-width: 360px; }

.toast { background: rgb(26, 26, 26); border: 1.5px solid rgb(51, 51, 51); color: rgb(255, 255, 255); padding: 14px 20px; border-radius: 16px; font-size: 14px; font-weight: 700; text-align: center; box-shadow: rgba(0, 0, 0, 0.6) 0px 8px 24px; opacity: 0; transform: translateY(-16px) scale(0.96); transition: 0.22s cubic-bezier(0.34, 1.4, 0.64, 1); pointer-events: none; width: 100%; box-sizing: border-box; }

.toast.show { opacity: 1; transform: translateY(0px) scale(1); }

.toast.success { border-color: var(--accent); background: rgb(10, 31, 16); color: rgb(0, 255, 115); }

.toast.error { border-color: rgb(255, 69, 58); background: rgb(31, 10, 10); color: rgb(255, 107, 107); }

@keyframes bounceIn { 
  0% { transform: scale(0.3); opacity: 0; }
  50% { transform: scale(1.15); opacity: 1; }
  70% { transform: scale(0.9); }
  100% { transform: scale(1); }
}

.green-lock { display: inline-block; width: 14px; height: 14px; position: relative; margin-bottom: 3px; }

.green-lock::before { content: ""; position: absolute; bottom: 0px; left: 50%; transform: translateX(-50%); width: 10px; height: 7px; background: rgb(0, 255, 115); border-radius: 2px; box-shadow: rgba(0, 255, 115, 0.8) 0px 0px 6px; }

.green-lock::after { content: ""; position: absolute; top: 0px; left: 50%; transform: translateX(-50%); width: 6px; height: 7px; border-width: 2px 2px medium; border-style: solid solid none; border-color: rgb(0, 255, 115) rgb(0, 255, 115) currentcolor; border-image: initial; border-radius: 4px 4px 0px 0px; box-shadow: rgba(0, 255, 115, 0.6) 0px 0px 6px; }

.part-btn.locked { background: rgb(13, 31, 20) !important; border: 1.5px solid rgb(0, 255, 115) !important; color: rgb(0, 255, 115) !important; box-shadow: rgba(0, 255, 115, 0.2) 0px 0px 10px !important; }
